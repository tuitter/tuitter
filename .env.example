# Copy this file to .env and set the values for the backend you want.

# Development backend
BACKEND_URL=https://your-dev-api.example.com
BACKEND_WS_URL=wss://your-dev-ws.example.com

# Production backend
# BACKEND_URL=https://your-prod-api.example.com
# BACKEND_WS_URL=wss://your-prod-ws.example.com

# Optional debug logging
# TUITTER_DEBUG=1

# Optional separate local profile storage
# TUITTER_PROFILE=dev
